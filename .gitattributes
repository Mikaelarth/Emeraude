# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Force LF on text-based files regardless of OS
*.py    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.kv    text eol=lf
*.spec  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.apk   binary
*.aab   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.db    binary
*.sqlite binary
